{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "prov hook codex post-tool-use",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "prov hook codex session-start",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "prov hook codex stop",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "prov hook codex user-prompt-submit",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  }
}
